# ── RFP Intelligence Copilot — environment variables ─────────────────────────
#
# Copy this file to .env and fill in the values.
# Never commit .env to source control.

# ── LLM ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=<your-jwt-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Storage backend ──────────────────────────────────────────────────────────
# Options: "local" | "gcs" | "hf"
#
#  local  (default) — writes JSON + files to DATA_DIR on the container filesystem.
#                     Survives restarts only if DATA_DIR is a mounted volume.
#
#  gcs              — Google Cloud Storage. Recommended for production.
#                     Files survive container restarts / redeploys with zero extra config.
#                     Requires GCS_BUCKET_NAME + GCP credentials (see below).
#
#  hf               — Hugging Face Dataset repo. Use for HF Spaces.
#                     Requires HF_TOKEN + HF_REPO_ID.
STORAGE_BACKEND=gcs

# ── Local filesystem (used by all backends as a local cache) ───────────────
# Root directory for cached project files inside the container.
# Default: /data  (set automatically by Dockerfile)
# Change only if you know what you're doing.
DATA_DIR=/data

# ── Google Cloud Storage (required when STORAGE_BACKEND=gcs) ──────────────
#
# Your existing GCS bucket.
GCS_BUCKET_NAME=my-unique-sourceiq-bucket
#
# Path to a GCP service account JSON key file INSIDE the container.
# Mount the file via Docker volume (see docker-compose.gcs.yml).
# The service account needs: roles/storage.objectAdmin on the bucket.
#
# Leave blank if running on GCP (Cloud Run / GKE / GCE) with Workload Identity —
# the GCP SDK picks up credentials from the metadata server automatically.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa-key.json
#
# GCP Project ID (optional — only needed if the SDK cannot infer it)
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>

# ── Hugging Face (required when STORAGE_BACKEND=hf) ───────────────────────
HF_TOKEN=
HF_REPO_ID=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email (optional — for communications module) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASSWORD=<your-app-password>
SMTP_FROM=<your-email@gmail.com>
